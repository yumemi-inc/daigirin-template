{
  "name": "daigirin-template",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:ymm-oss/daigirin-template.git",
  "author": "YUMEMI Daigirin Production Committee",
  "license": "MIT",
  "scripts": {
    "lint": "textlint ./book/manuscripts/",
    "start": "run-s build open",
    "generate": "node ./scripts/generate-manuscripts.cts --force",
    "generate:if-missing": "node ./scripts/generate-manuscripts.cts --if-missing",
    "build": "run-s generate:if-missing _build:ebook _stamp:ebook-blank-pages",
    "build:press": "run-s generate:if-missing _build:press:vivliostyle _stamp:press-blank-pages",
    "_build:ebook": "cd ./book/ && vivliostyle build",
    "_build:press:vivliostyle": "cd ./book/ && vivliostyle build --config vivliostyle.config.press.local.js",
    "_stamp:ebook-blank-pages": "node ./scripts/stampBlankPageNumbers.ts ./book/output/ebook.pdf",
    "_stamp:press-blank-pages": "node ./scripts/stampBlankPageNumbers.ts ./book/output/press.pdf",
    "open": "open ./book/output/ebook.pdf",
    "clean": "rm -rf ./book/output/",
    "cover": "node ./scripts/InsertCoverImage.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "check": "biome check",
    "check-write": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@vivliostyle/cli": "10.5.0",
    "jest": "^30.3.0",
    "npm-run-all2": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "textlint": "^15.5.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-spacing": "^2.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-spellcheck-tech-word": "^5.0.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3",
    "yaml": "^2.8.3"
  },
  "packageManager": "yarn@4.14.1"
}
