{
  "name": "daigirin-template",
  "version": "1.0.0",
  "main": "index.js",
  "repository": "git@github.com:ymm-oss/daigirin-template.git",
  "author": "YUMEMI Daigirin Production Committee",
  "license": "MIT",
  "scripts": {
    "lint": "textlint ./book/manuscripts/",
    "start": "run-s build open",
    "generate": "node ./scripts/generate-manuscripts.cts",
    "edit": "run-s generate _prepare:edit",
    "build": "run-s generate _build:ebook",
    "build:press": "run-s generate _build:press:vivliostyle",
    "_prepare:edit": "node ./scripts/prepare-editable-manuscripts.cts",
    "_build:ebook": "cd ./book/ && vivliostyle build",
    "_build:press:vivliostyle": "cd ./book/ && vivliostyle build --config vivliostyle.config.press.local.js",
    "open": "open ./book/output/ebook.pdf",
    "clean": "rm -rf ./book/output/ ./book/manuscripts/generated/",
    "clean:edited": "rm -rf ./book/manuscripts/edited/",
    "cover": "node ./scripts/InsertCoverImage.ts",
    "test": "vitest run",
    "check": "biome check",
    "check-write": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@textlint-ja/textlint-rule-preset-ai-writing": "^1.6.1",
    "@types/node": "^25.6.0",
    "@vivliostyle/cli": "10.5.0",
    "npm-run-all2": "^8.0.4",
    "pdf-lib": "^1.17.1",
    "textlint": "^15.5.1",
    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-rule-preset-ja-spacing": "^2.3.0",
    "textlint-rule-preset-ja-technical-writing": "^12.0.2",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-spellcheck-tech-word": "^5.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "packageManager": "yarn@4.14.1"
}
