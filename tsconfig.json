{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./scripts/*"]
    }
  },
  "include": ["scripts/**/*.ts", "scripts/**/*.cts"]
}
